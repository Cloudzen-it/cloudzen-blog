---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">
			<img src="/images/logo__cloudzen-white.svg" alt={SITE_TITLE} height="28" />
		</a>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="https://cloudzendevops.com" target="_blank">Cloudzen</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.linkedin.com/company/cloudzen-sl" target="_blank" aria-label="LinkedIn">
				<svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(10, 10, 10, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}

	nav {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0 1.5em;
		height: 64px;
	}

	.logo img {
		display: block;
		border-radius: 0;
		transition: var(--transition);
	}

	.logo:hover img {
		opacity: 0.8;
	}

	.nav-links {
		display: flex;
		gap: 0.25em;
	}

	.social-links {
		display: flex;
		align-items: center;
	}

	.social-links a {
		color: var(--text-muted);
		transition: var(--transition);
		display: flex;
		align-items: center;
	}

	.social-links a:hover {
		color: var(--violet);
	}

	@media (max-width: 720px) {
		nav {
			padding: 0 1em;
		}

		.social-links {
			display: none;
		}
	}
</style>
