---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<img src="/images/logo__cloudzen-white.svg" alt="Cloudzen" height="22" />
			<span class="copyright">&copy; {today.getFullYear()} Cloudzen S.L.</span>
		</div>
		<div class="footer-links">
			<a href="https://cloudzendevops.com" target="_blank">Website</a>
			<a href="https://www.linkedin.com/company/cloudzen-sl" target="_blank">LinkedIn</a>
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 2em 1.5em;
		margin-top: 4em;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.footer-brand {
		display: flex;
		align-items: center;
		gap: 1em;
	}

	.footer-brand img {
		border-radius: 0;
	}

	.copyright {
		color: var(--text-muted);
		font-size: 0.85em;
	}

	.footer-links {
		display: flex;
		gap: 1.5em;
	}

	.footer-links a {
		color: var(--text-muted);
		font-size: 0.85em;
		text-decoration: none;
		transition: var(--transition);
	}

	.footer-links a:hover {
		color: var(--violet);
	}

	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
			gap: 1em;
			text-align: center;
		}
	}
</style>
